---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
---

<Base title="КФУ — Амаль Хасанбаев" description="Строю студенческое IT-сообщество в КФУ">
  <Nav />

  <main>
    <section class="hero">
      <div class="container">
        <p class="breadcrumb"><a href="/side-hustles">Не код</a> / КФУ</p>
        <span class="page-tag">Университет</span>
        <h1>КФУ</h1>
        <p class="page-bio">
          Работаю в КФУ — официально лаборант кафедры, по факту строю студенческое
          IT-сообщество. Помогаю студентам с административными вопросами, пишу методические
          материалы, участвую в конкурсах стартапов, представляю студенческие организации
          как амбассадор.
        </p>
      </div>
    </section>

    <section class="details-section">
      <div class="container">
        <div class="details-grid">
          <div class="detail-item">
            <span class="detail-label">Сообщество</span>
            <span class="detail-value">KFU_ITCom</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Роль</span>
            <span class="detail-value">Community Lead</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Чем занимаюсь</span>
            <div class="detail-list">
              <span>Студенческое IT-сообщество KFU_ITCom</span>
              <span>Методические материалы</span>
              <span>Конкурсы стартапов</span>
              <span>Амбассадор организаций</span>
              <span>Административная поддержка студентов</span>
              <span>Староста группы, потока и всех 4 курсов направления</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <span>© 2026 om1ji</span>
      <a href="/side-hustles" class="back-link">← Не код</a>
    </div>
  </footer>
</Base>

<style>
  main {
    padding-top: 56px;
  }

  section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--text);
    opacity: 1;
  }

  .page-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    background: var(--accent-dim);
    border-radius: 4px;
    padding: 3px 9px;
    margin-bottom: 20px;
  }

  h1 {
    font-size: 3rem;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 24px;
  }

  .page-bio {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 620px;
  }

  .details-section {
    border-bottom: none;
  }

  .details-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .detail-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    align-items: start;
  }

  .detail-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    padding-top: 3px;
  }

  .detail-value {
    font-size: 0.95rem;
    color: var(--text);
  }

  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .detail-list span {
    font-size: 0.95rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .detail-list span::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  footer {
    padding: 32px 0;
  }

  footer .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  footer span {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .back-link {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--text);
    opacity: 1;
  }
</style>
