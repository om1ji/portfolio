---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, stack, year, github, demo } = project.data;
---

<Base title={`${title} — Амаль Хасанбаев`} description={description}>
  <Nav />

  <main>
    <div class="container">
      <a href="/#projects" class="back">← Проекты</a>

      <header>
        <div class="header-meta">
          {year && <span class="year">{year}</span>}
          <div class="stack">
            {stack.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <h1>{title}</h1>
        <p class="description">{description}</p>
        <div class="header-links">
          {github && (
            <a href={github} target="_blank" rel="noopener" class="btn">
              GitHub ↗
            </a>
          )}
          {demo && (
            <a href={demo} target="_blank" rel="noopener" class="btn btn-accent">
              Demo ↗
            </a>
          )}
        </div>
      </header>

      <article class="prose">
        <Content />
      </article>
    </div>
  </main>

  <footer>
    <div class="container">
      <a href="/#projects" class="back">← Все проекты</a>
    </div>
  </footer>
</Base>

<style>
  main {
    padding-top: 56px;
  }

  .container {
    padding-top: 64px;
    padding-bottom: 96px;
  }

  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 48px;
    transition: color 0.15s;
  }
  .back:hover {
    color: var(--text);
    opacity: 1;
  }

  header {
    margin-bottom: 64px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  .header-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-dim);
    border-radius: 4px;
    padding: 2px 8px;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .description {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 540px;
    line-height: 1.65;
    margin-bottom: 32px;
  }
  .header-links {
    display: flex;
    gap: 12px;
  }
  .btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 16px;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn:hover {
    border-color: var(--text-muted);
    color: var(--text);
    opacity: 1;
  }
  .btn-accent {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .btn-accent:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Prose */
  .prose {
    color: var(--text-muted);
    line-height: 1.8;
    font-size: 0.95rem;
    max-width: 640px;
  }
  .prose :global(h2) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 40px 0 16px;
    letter-spacing: -0.3px;
  }
  .prose :global(h3) {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    margin: 28px 0 12px;
  }
  .prose :global(p) {
    margin-bottom: 16px;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .prose :global(li) {
    margin-bottom: 6px;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    color: var(--text);
  }
  .prose :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin-bottom: 20px;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.85rem;
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  footer {
    padding: 32px 0 48px;
    border-top: 1px solid var(--border);
  }
</style>
